{
  "version": 2,
  "framework": null,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "builds": [
    { "src": "api/account.js",           "use": "@vercel/node" },
    { "src": "api/billing-portal.js",    "use": "@vercel/node" },
    { "src": "api/chat.js",              "use": "@vercel/node" },
    { "src": "api/create-checkout.js",   "use": "@vercel/node" },
    { "src": "api/generate-image.js",    "use": "@vercel/node" },
    { "src": "api/send-verification.js", "use": "@vercel/node" },
    { "src": "api/stripe-webhook.js",    "use": "@vercel/node" },
    { "src": "api/upload-file.js",       "use": "@vercel/node" },
    { "src": "api/verify-email.js",      "use": "@vercel/node" },
    { "src": "api/video.js",             "use": "@vercel/node" },
    { "src": "index.html",               "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/stripe-webhook",
      "dest": "/api/stripe-webhook.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/account",
      "dest": "/api/account.js"
    },
    {
      "src": "/api/billing-portal",
      "dest": "/api/billing-portal.js"
    },
    {
      "src": "/api/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/create-checkout",
      "dest": "/api/create-checkout.js"
    },
    {
      "src": "/api/generate-image",
      "dest": "/api/generate-image.js"
    },
    {
      "src": "/api/send-verification",
      "dest": "/api/send-verification.js"
    },
    {
      "src": "/api/upload-file",
      "dest": "/api/upload-file.js"
    },
    {
      "src": "/api/verify-email",
      "dest": "/api/verify-email.js"
    },
    {
      "src": "/api/video",
      "dest": "/api/video.js"
    },
    {
      "src": "/(.*\\.(js|css|png|ico|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Cache-Control",           "value": "no-store" }
      ]
    },
    {
      "source": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|webp|woff|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
