{
  "version": 2,
  "framework": null,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "functions": {
    "api/chat.js":             { "maxDuration": 60 },
    "api/generate-image.js":   { "maxDuration": 120 },
    "api/generate-video.js":   { "maxDuration": 120 },
    "api/video-route.js":      { "maxDuration": 120 },
    "api/upload-file.js":      { "maxDuration": 30 },
    "api/stripe-webhook.js":   { "maxDuration": 30 },
    "api/send-verification.js":{ "maxDuration": 30 },
    "api/verify-email.js":     { "maxDuration": 15 },
    "api/create-checkout.js":  { "maxDuration": 15 },
    "api/billing-portal.js":   { "maxDuration": 15 },
    "api/plan.js":             { "maxDuration": 15 },
    "api/usage.js":            { "maxDuration": 10 },
    "api/gemini.js":           { "maxDuration": 60 }
  },
  "routes": [
    {
      "src": "/api/stripe-webhook",
      "dest": "/api/stripe-webhook.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/(.*\\.(js|css|png|ico|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|html))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Cache-Control",           "value": "no-store" }
      ]
    },
    {
      "source": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|webp|woff|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
